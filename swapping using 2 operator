
//swapping without 3rd variable (using 2 operator)

class Main {
    public static void main(String[] args) {
        int x,y;
        x=10;
        y=5;
        System.out.println("Before swapping");
        System.out.println("x="+x+" y="+y);
       x+=y;
       y=x-y;
       x-=y;
       System.out.println("After swapping");
       System.out.println("x="+x+" y="+y);
       
    }
}

